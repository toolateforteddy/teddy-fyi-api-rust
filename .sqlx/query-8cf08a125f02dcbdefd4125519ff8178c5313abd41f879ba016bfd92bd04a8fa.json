{
  "db_name": "PostgreSQL",
  "query": "SELECT DISTINCT s.id, s.name, s.position, s.\"isDefaultSupported\" as is_default_supported, s.\"userId\" as user_id, s.version, s.is_deleted, s.sync_state, s.\"listId\" as list_id\n           FROM stores s\n           LEFT JOIN grocery_list_members glm ON s.\"listId\" = glm.\"listId\" AND glm.\"userId\" = $1 AND glm.is_deleted = FALSE\n           WHERE (s.\"userId\" = $1 OR glm.id IS NOT NULL)\n             AND s.updated_at > $2\n             AND ($4 OR s.updated_by_client != $3 OR s.updated_by_client IS NULL)",
