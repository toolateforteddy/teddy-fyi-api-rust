{
  "db_name": "PostgreSQL",
  "query": "SELECT DISTINCT gl.id, gl.name, gl.\"ownerId\" as owner_id, gl.\"createdAt\" as created_at, gl.version, gl.is_deleted, gl.sync_state\n               FROM grocery_lists gl\n               JOIN grocery_list_members glm ON gl.id = glm.\"listId\"\n               WHERE glm.\"userId\" = $1\n                 AND gl.updated_at > $2\n                 AND (gl.updated_by_client != $3 OR gl.updated_by_client IS NULL)",
