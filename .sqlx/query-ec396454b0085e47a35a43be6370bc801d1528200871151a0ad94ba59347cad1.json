{
  "db_name": "PostgreSQL",
  "query": "SELECT DISTINCT glm.id, glm.\"listId\" as list_id, glm.\"userId\" as user_id, glm.role, glm.\"joinedAt\" as joined_at, glm.version, glm.is_deleted, glm.sync_state\n           FROM grocery_list_members glm\n           JOIN grocery_list_members my_glm ON glm.\"listId\" = my_glm.\"listId\" AND my_glm.is_deleted = FALSE\n           WHERE my_glm.\"userId\" = $1\n             AND glm.updated_at > $2\n             AND ($4 OR glm.updated_by_client != $3 OR glm.updated_by_client IS NULL)",
